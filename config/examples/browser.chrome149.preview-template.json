{
  "schema_version": "cba-browser-config/2",
  "product": "chrome",
  "browser_contract_version": "cope-visible-browser/v1",
  "entry_url": "https://copilot.example.invalid/chat",
  "approved_hosts": [
    {
      "hostname": "copilot.example.invalid",
      "allow_subdomains": false
    }
  ],
  "manual_authentication_hosts": [
    {
      "hostname": "login.example.invalid",
      "allow_subdomains": false
    }
  ],
  "expected_identity": "REPLACE_WITH_APPROVED_WORK_ACCOUNT_DISPLAY_STRING",
  "require_protection_indicator": true,
  "profile_directory": "C:\\Users\\REPLACE_WITH_WINDOWS_USER\\AppData\\Local\\CopilotBrowserAgentChromeProfile",
  "browser_executable": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
  "browser_version": "REPLACE_WITH_EXACT_APPROVED_CHROME_VERSION",
  "browser_executable_sha256": "REPLACE_WITH_LOWERCASE_SHA256_OF_APPROVED_CHROME_EXECUTABLE",
  "max_message_chars": 200000,
  "max_response_chars": 1000000,
  "waits": {
    "actionMs": 15000,
    "submissionConfirmationMs": 12000,
    "responseMs": 180000,
    "manualReadinessMs": 600000,
    "pollMs": 250,
    "stableSamples": 3,
    "minimumStableMs": 750
  },
  "ui_contract": {
    "version": "copilot-ui/v1:uncertified-chrome149-template",
    "certifiedSurface": "UNDEPLOYABLE TEMPLATE — replace with the exact certified tenant surface",
    "submissionStrategy": "send-control",
    "groups": {
      "shell": {
        "signal": "shell",
        "candidates": [
          {
            "kind": "role",
            "role": "main"
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      },
      "conversation": {
        "signal": "conversation",
        "candidates": [
          {
            "kind": "role",
            "role": "main"
          },
          {
            "kind": "test-id",
            "testId": {
              "source": "chat|conversation",
              "flags": "iu"
            }
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      },
      "composer": {
        "signal": "composer",
        "candidates": [
          {
            "kind": "role",
            "role": "textbox",
            "name": {
              "source": "message|ask|copilot",
              "flags": "iu"
            }
          },
          {
            "kind": "placeholder",
            "placeholder": {
              "source": "message|ask|copilot",
              "flags": "iu"
            }
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "value-and-text"
      },
      "send": {
        "signal": "send",
        "candidates": [
          {
            "kind": "role",
            "role": "button",
            "name": {
              "source": "send|submit",
              "flags": "iu"
            }
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      },
      "responses": {
        "signal": "responses",
        "candidates": [
          {
            "kind": "test-id",
            "testId": {
              "source": "assistant.*message|response",
              "flags": "iu"
            }
          },
          {
            "kind": "css",
            "selector": "[data-content=\"ai-message\"], [data-author=\"assistant\"]"
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 200,
        "capture": "text"
      },
      "user-messages": {
        "signal": "user-messages",
        "candidates": [
          {
            "kind": "test-id",
            "testId": {
              "source": "user.*message",
              "flags": "iu"
            }
          },
          {
            "kind": "css",
            "selector": "[data-content=\"user-message\"], [data-author=\"user\"]"
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 200,
        "capture": "text"
      },
      "streaming": {
        "signal": "streaming",
        "candidates": [
          {
            "kind": "role",
            "role": "progressbar"
          },
          {
            "kind": "css",
            "selector": "[aria-busy=\"true\"]"
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      },
      "identity": {
        "signal": "identity",
        "candidates": [
          {
            "kind": "role",
            "role": "button",
            "name": "REPLACE_WITH_APPROVED_WORK_ACCOUNT_DISPLAY_STRING",
            "exact": true
          },
          {
            "kind": "text",
            "text": "REPLACE_WITH_APPROVED_WORK_ACCOUNT_DISPLAY_STRING",
            "exact": true
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "text"
      },
      "protection": {
        "signal": "protection",
        "candidates": [
          {
            "kind": "role",
            "role": "status",
            "name": {
              "source": "^(?:enterprise data protection|commercial data protection)$",
              "flags": "iu"
            }
          },
          {
            "kind": "role",
            "role": "img",
            "name": {
              "source": "^(?:enterprise data protection|commercial data protection)$",
              "flags": "iu"
            }
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "text"
      },
      "signed-out": {
        "signal": "signed-out",
        "candidates": [
          {
            "kind": "role",
            "role": "button",
            "name": {
              "source": "sign in|log in",
              "flags": "iu"
            }
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      },
      "mfa": {
        "signal": "mfa",
        "candidates": [
          {
            "kind": "text",
            "text": {
              "source": "approve sign.in|verification code|multi.factor",
              "flags": "iu"
            }
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      },
      "consent": {
        "signal": "consent",
        "candidates": [
          {
            "kind": "text",
            "text": {
              "source": "permissions requested|consent|accept",
              "flags": "iu"
            }
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      },
      "throttled": {
        "signal": "throttled",
        "candidates": [
          {
            "kind": "text",
            "text": {
              "source": "too many requests|try again later|rate limit",
              "flags": "iu"
            }
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      },
      "service-error": {
        "signal": "service-error",
        "candidates": [
          {
            "kind": "text",
            "text": {
              "source": "something went wrong|service unavailable|couldn't respond",
              "flags": "iu"
            }
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      },
      "modal": {
        "signal": "modal",
        "candidates": [
          {
            "kind": "role",
            "role": "dialog"
          }
        ],
        "minimumCandidateMatches": 1,
        "maximumElements": 20,
        "capture": "presence"
      }
    }
  }
}
